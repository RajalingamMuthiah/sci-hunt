# ─── Backend Environment Variables ───────────────────────────────────────────
# Copy this file to backend/.env and fill in real values.
# The Spring Boot app reads these via OS environment variables or a .env loader.
#
# For local dev you can also export them in your shell before running mvn, e.g.:
#   $env:MONGODB_URI="mongodb://localhost:27017/scientis_hunt"  (PowerShell)
#   export MONGODB_URI=mongodb://localhost:27017/scientis_hunt  (bash)
# ─────────────────────────────────────────────────────────────────────────────

# MongoDB connection string
# Local:  mongodb://localhost:27017/scientis_hunt
# Atlas:  mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/scientis_hunt?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/scientis_hunt

# JWT signing secret — MUST be at least 32 characters, keep this secret!
JWT_SECRET=CHANGE_ME_to_a_long_random_string_32chars_minimum

# The frontend origin allowed by CORS (no trailing slash)
FRONTEND_ORIGIN=http://localhost:3000

# Server port (default 8080)
PORT=8080

# Bootstrap super-admin credentials (created on first startup if no admin exists)
BOOTSTRAP_SUPER_ADMIN_EMAIL=admin@scientishunt.local
BOOTSTRAP_SUPER_ADMIN_PASSWORD=Admin@123456

# Set to true in production (requires HTTPS so cookies are Secure)
SECURE_COOKIES=false
